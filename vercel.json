{
  "version": 2,
  "buildCommand": "cd gui && npm install && npm run build",
  "outputDirectory": "gui/dist",
  "installCommand": "cd gui && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
